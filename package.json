{
  "name": "storagemaxxing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": "1.3.11"
  },
  "scripts": {
    "dev": "bun run build && bun run serve.ts",
    "build": "bun build ./src/index.tsx --outdir ./dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "bun x prettier --write ."
  },
  "dependencies": {
    "gl-matrix": "^3.4.4",
    "glpk.js": "^5.0.0",
    "idb-keyval": "^6.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/gl-matrix": "^3.2.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "bun-types": "^1.3.11",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-functional": "^6.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "typescript": "^6.0.2"
  }
