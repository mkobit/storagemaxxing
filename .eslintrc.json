{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": [
      "./tsconfig.json",
      "apps/*/tsconfig.json",
      "packages/*/tsconfig.json"
    ],
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["@typescript-eslint", "functional", "import"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:import/recommended",
    "plugin:import/typescript"
  ],
  "rules": {
    "functional/no-let": "error",
    "functional/immutable-data": ["error", { "ignoreImmediateMutation": true }],
    "functional/no-loop-statements": "error",
    "functional/prefer-readonly-type": "error",
    "complexity": ["error", 8],
    "max-depth": ["error", 3],
    "max-params": ["error", 4],
    "import/no-cycle": "error",
    "import/no-default-export": "error",
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/prefer-readonly": "error",
    "@typescript-eslint/switch-exhaustiveness-check": "error",
    "@typescript-eslint/consistent-type-assertions": "off"
  },
  "overrides": [
    {
      "files": [
        "packages/geometry/src/**/*.ts",
        "packages/packer/src/**/*.ts",
        "packages/catalog/src/**/*.ts",
        "packages/solver/src/**/*.ts"
      ],
      "excludedFiles": ["**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "functional/no-expression-statements": "error",
        "functional/no-throw-statements": "error",
        "functional/no-try-statements": "error"
      }
    },
    {
      "files": [
        "packages/store/src/**/*.ts",
        "apps/web/src/**/*.tsx",
        "apps/web/src/**/*.ts"
      ],
      "excludedFiles": ["**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "functional/no-expression-statements": "off",
        "functional/no-return-void": "off"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "rules": {
        "functional/no-expression-statements": "off",
        "functional/no-return-void": "off"
      }
    }
  ],
  "settings": {
    "import/resolver": {
      "typescript": {
        "alwaysTryTypes": true,
        "project": [
          "./tsconfig.json",
          "apps/*/tsconfig.json",
          "packages/*/tsconfig.json"
        ]
      },
      "node": true
    }
  }
}
