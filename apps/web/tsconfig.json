{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@storagemaxxing/geometry/*": ["../../packages/geometry/src/*"],
      "@storagemaxxing/catalog/*": ["../../packages/catalog/src/*"],
      "@storagemaxxing/packer/*": ["../../packages/packer/src/*"],
      "@storagemaxxing/solver/*": ["../../packages/solver/src/*"],
      "@storagemaxxing/assembly/*": ["../../packages/assembly/src/*"],
      "@storagemaxxing/store/*": ["../../packages/store/src/*"]
    },
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true
  },
  "include": ["src", "serve.ts"]
}
