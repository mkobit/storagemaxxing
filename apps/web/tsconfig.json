{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "baseUrl": ".",
    "checkJs": true,
    "ignoreDeprecations": "6.0",
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@storagemaxxing/assembly/*": ["../../packages/assembly/src/*"],
      "@storagemaxxing/catalog/*": ["../../packages/catalog/src/*"],
      "@storagemaxxing/geometry/*": ["../../packages/geometry/src/*"],
      "@storagemaxxing/packer/*": ["../../packages/packer/src/*"],
      "@storagemaxxing/solver/*": ["../../packages/solver/src/*"],
      "@storagemaxxing/store/*": ["../../packages/store/src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext"
  },
  "extends": "../../tsconfig.json",
  "include": [
    "src",
    "serve.ts",
    ".storybook/**/*",
    "vitest.config.ts",
    "vitest.shims.d.ts"
  ]
}
